# GitHub App credentials
GITHUB_APP_ID=123456
# PEM private key. In a .env file, put it on one line with literal \n escapes,
# or export it as a real multi-line value in your process environment.
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_WEBHOOK_SECRET=replace-with-your-webhook-secret

# Claude API
ANTHROPIC_API_KEY=sk-ant-...
REVIEW_MODEL=claude-opus-4-8

# Tunables (optional — defaults shown)
MAX_FILES_PER_PR=40
MAX_NITS_PER_FILE=3
