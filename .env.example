# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# See the "Installation" section of README.md for how to obtain these.

# ── GitHub App ───────────────────────────────────────────────────────────────
# App ID: shown on the App's General page (Settings → Developer settings → Apps).
GITHUB_APP_ID=123456

# The App's RSA private key (downloaded as a .pem when you generate a key).
# It must be a SINGLE LINE here, with newlines written as literal \n — the app
# un-escapes them at load time. Append a downloaded key file directly (writing
# awk's output through echo/$(...) in some shells re-expands the \n and breaks it):
#   { printf 'GITHUB_PRIVATE_KEY='; awk 'BEGIN{ORS="\\n"} 1' gh-app.pem; echo; } >> .env
GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n

# The webhook secret you set when creating the App (used to verify signatures).
GITHUB_WEBHOOK_SECRET=replace-with-your-webhook-secret

# ── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
REVIEW_MODEL=claude-opus-4-8

# ── Tunables (optional — defaults shown) ─────────────────────────────────────
MAX_FILES_PER_PR=40          # cap files reviewed per PR (cost/scope guard)
MAX_NITS_PER_FILE=3          # keep all blockers/warnings; cap nits per file
MAX_DIFF_TOKENS=16000        # per-unit budget; larger files reviewed hunk-by-hunk
MAX_REVIEW_RETRIES=3         # per-file Claude review attempts before giving up
ANTHROPIC_MAX_RETRIES=4      # SDK-level retry budget for 429/5xx
MAX_HTTP_RETRIES=4           # GitHub REST retry budget for 429/5xx
REQUEST_TIMEOUT=30           # seconds, per HTTP request
# SKIP_GLOBS is a JSON list; omit to use the built-in defaults (lockfiles,
# vendor/, node_modules/, build artifacts, images, etc.). Example:
# SKIP_GLOBS=["*.lock","vendor/*","dist/*"]
